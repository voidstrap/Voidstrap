<ui:UiPage x:Class="Voidstrap.UI.Elements.Settings.Pages.ExtensionPage"
           xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
           xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
           xmlns:controls="clr-namespace:Voidstrap.UI.Elements.Controls"
           xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
           xmlns:local="clr-namespace:Voidstrap.UI.Elements.Settings.Pages"
           xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
           xmlns:ui="http://schemas.lepo.co/wpfui/2022/xaml"
           Title="Extensions"
           Scrollable="True"
           d:DesignHeight="900"
           d:DesignWidth="900"
           mc:Ignorable="d">

    <Grid>
        <!-- Main content -->
        <StackPanel Margin="0,0,14,14">
            <TextBlock
                FontSize="14"
                Margin="0,0,0,16"
                Foreground="{DynamicResource TextFillColorSecondaryBrush}"
                Text="Extensions for Voidstrap and its Community." />
            <ui:Card>
                <StackPanel Orientation="Vertical">
                    <!-- Fleasion Option -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Image Grid.Column="0" Width="50" Height="50" Margin="0,6,10,0"
                               Source="https://avatars.githubusercontent.com/u/186699266" />

                        <controls:OptionControl Grid.Column="1" HorizontalAlignment="Stretch"
                                                Header="Fleasion"
                                                Description="Allows you to replace Roblox game assets in real time. It lets you swap textures, audio, meshes, animations, and more. It can also dump Roblox games."
                                                HelpLink="https://voidstrapp.netlify.app/documentation/documentation#fleasion">
                            <StackPanel>
                                <ui:ToggleSwitch IsChecked="{Binding fleasionenabler, Mode=TwoWay}" />
                                <ui:Button Content="Open" Margin="0,8,0,0"
                                           HorizontalAlignment="Left"
                                           Click="OpenFleasion_Click"/>
                            </StackPanel>
                        </controls:OptionControl>
                    </Grid>

                    <!-- AniWatch Option -->
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>

                        <Image Grid.Column="0" Width="50" Height="50" Margin="0,6,10,0"
                               Source="https://online.fliphtml5.com/rxkgl/rnfj/files/large/95e7a87a9e858ca0085f76054ed3a16d.webp?1701104491" />

                        <controls:OptionControl Grid.Column="1" HorizontalAlignment="Stretch"
                                                Header="AniWatch"
                                                Description="Allows you to watch Anime while using Voidstrap/Roblox."
                                                HelpLink="https://voidstrapp.netlify.app/documentation/documentation#aniwatch">
                            <StackPanel>
                                <ui:ToggleSwitch IsChecked="{Binding aniwatchenabler, Mode=TwoWay}" />
                                <ui:Button Content="Open" Margin="0,8,0,0"
                                           HorizontalAlignment="Left"
                                           Click="OpenAniWatchWindow_Click"/>
                            </StackPanel>
                        </controls:OptionControl>
                    </Grid>
                </StackPanel>
            </ui:Card>
        </StackPanel>

        <Grid x:Name="ProgressOverlay" Visibility="Hidden">
            <Border HorizontalAlignment="Center" VerticalAlignment="Center"
        Background="{DynamicResource CardBackgroundBrush}"
        Padding="20" CornerRadius="12">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock x:Name="ProgressTitle" FontSize="16" FontWeight="Bold"
                   Text="Processing..." Margin="0,0,0,10" HorizontalAlignment="Center"/>
                    <ProgressBar x:Name="ProgressBar" Width="450" Height="12" IsIndeterminate="True"/>
                    <ui:Button Content="Cancel" Margin="0,8,0,0" Width="180" HorizontalAlignment="Center"
                   Click="CancelDownload_Click"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</ui:UiPage>